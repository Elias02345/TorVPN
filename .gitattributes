# Normalize all text files to LF in the repository and the working tree.
# This makes line endings deterministic across Linux/macOS/Windows and prevents
# CRLF churn on Windows (where core.autocrlf=true would otherwise rewrite
# Flutter-generated files on every `flutter pub get`).
* text=auto eol=lf

# Binary assets must never be line-ending converted.
*.png   binary
*.ico   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ttf   binary
*.otf   binary
*.jar   binary
*.jks   binary
*.keystore binary
