[Unit]
Description=TorTunnel privileged helper
After=network-online.target

[Service]
Type=notify
ExecStart=/usr/libexec/tortunnel/tortunnel-helper --strict
Restart=on-failure
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/tortunnel /var/lib/tortunnel

[Install]
WantedBy=multi-user.target
